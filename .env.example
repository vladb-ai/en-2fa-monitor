# L1 JSON-RPC URL (must match the network: sepolia or mainnet).
ETH_RPC_URL=https://ethereum-rpc.publicnode.com

# ExecutionMultisigValidator contract address.
VALIDATOR_ADDRESS=0x0000000000000000000000000000000000000000

# Chain (diamond proxy) address, used to read execution progress.
CHAIN_ADDRESS=0x0000000000000000000000000000000000000000

# Comma-separated signer addresses to watch (the set you fund/register).
SIGNERS=0xaaaa...,0xbbbb...,0xcccc...

# Label used in alert messages.
NETWORK_NAME=era-mainnet

# Alert if a signer's L1 balance drops below this many ETH.
MIN_BALANCE_ETH=0.05

# Minimum committed-but-not-executed backlog that arms the stall check. The real guard is
# STALL_SECS; 1 means "any unexecuted batch that sits for STALL_SECS counts as a halt".
EXEC_LAG_ALERT=1

# How long execution / a signer may stay idle before alerting (seconds).
STALL_SECS=3600

# Seconds between monitor cycles.
POLL_INTERVAL_SECS=60

# Re-send a still-firing alert at most this often (seconds).
ALERT_COOLDOWN_SECS=3600

# Post an "all healthy" summary this often (seconds; 0 disables).
HEARTBEAT_SECS=0

# Alert channels (configure at least one; otherwise alerts are only logged).
SLACK_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
